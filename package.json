{
  "name": "@forgeax/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Product shell: spawn engine/interface, host the @forgeax/orchestrator orchestration layer in-process, serve SPA + vite proxy, HTTP+WS bridge for UI",
  "main": "src/main.ts",
  "exports": {
    ".": "./src/main.ts",
    "./composition": "./src/composition.ts"
  },
  "bin": {
    "forgeax-server": "./bin/forgeax-server"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "migrate:video-assets": "bun scripts/migrate-video-assets.ts",
    "e2e:inner-ring": "bun test/inner-ring-e2e.ts",
    "e2e:full": "bun test/full-flow-e2e.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@aws-sdk/s3-request-presigner": "^3.1091.0",
    "@forgeax/agent-host": "workspace:*",
    "@forgeax/agent-runtime": "workspace:*",
    "@forgeax/cli": "workspace:*",
    "@forgeax/orchestrator": "workspace:*",
    "@forgeax/platform-io": "workspace:*",
    "cos-nodejs-sdk-v5": "^3.0.0",
    "hono": "^4.6.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.3"
  }
}
