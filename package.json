{
  "name": "@forgeax/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local daemon orchestrator: spawn engine/interface, in-process host forgeax-cli, HTTP+WS bridge for UI",
  "main": "src/main.ts",
  "bin": {
    "forgeax-server": "./bin/forgeax-server",
    "forgeax-pack": "./bin/forgeax-pack"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test/e2e-multi-cli.ts",
    "test:e2e-p6c": "bun test/e2e-p6c-reload-resume.ts",
    "test:e2e-dashboard": "bun test/e2e-dashboard-api.ts"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.53",
    "@google/genai": "^1.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "minimatch": "^10.2.5",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2",
    "zod": "^3.25.0",
    "@forgeax/engine-project": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.3"
  }
}
